---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('learn');
const sorted = articles.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<Layout title="AI 知识 — AI Toolbox">
  <div class="mx-auto max-w-6xl px-5 py-10 sm:py-14">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-text">AI 知识</h1>
      <p class="mt-2 text-sm text-text-secondary">从入门到精通的 AI 学习路径与知识文档</p>
    </div>

    <!-- Learning Path -->
    <div class="mb-14">
      <h2 class="mb-5 text-xs font-semibold uppercase tracking-widest text-text-tertiary">推荐学习路径</h2>
      <div class="glass-card rounded-2xl p-6 sm:p-8">
        <ol class="space-y-4 max-w-lg">
          {sorted.slice(0, 6).map((a, i) => (
            <li class="flex items-start gap-4 group">
              <span class="shrink-0 flex h-7 w-7 items-center justify-center rounded-full bg-slate-50/80 border border-border text-[11px] font-mono font-medium text-text-muted tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
              <a href={`/learn/${a.id}`} class="flex-1 pt-0.5 no-underline group-hover:no-underline">
                <span class="text-[14px] font-medium text-text group-hover:text-accent transition-colors">{a.data.title}</span>
                {a.data.description && (
                  <p class="mt-0.5 text-[12px] text-text-muted line-clamp-1">{a.data.description}</p>
                )}
              </a>
              {a.data.level && (
                <span class="shrink-0 mt-0.5 text-[10px] px-2 py-0.5 rounded-md border border-border bg-white/60 text-text-tertiary">{a.data.level}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- All Articles Grid -->
    <div>
      <h2 class="mb-5 text-xs font-semibold uppercase tracking-widest text-text-tertiary">全部文档</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sorted.map((article) => (
          <a href={`/learn/${article.id}`} class="glass-card glass-shine group block rounded-xl p-5 no-underline">
            <div class="flex items-center gap-2 mb-2">
              {article.data.level && (
                <span class="text-[10px] px-2 py-0.5 rounded-md border border-border bg-slate-50/60 text-text-muted uppercase tracking-wider">{article.data.level}</span>
              )}
              {article.data.category && (
                <span class="text-[10px] text-text-muted">{article.data.category}</span>
              )}
            </div>
            <h3 class="text-[15px] font-semibold text-text leading-snug group-hover:text-text mt-1">{article.data.title}</h3>
            {article.data.description && (
              <p class="mt-2 text-[12px] text-text-muted line-clamp-2 leading-relaxed">{article.data.description}</p>
            )}
            <div class="mt-4 pt-3 border-t border-border/50 flex items-center justify-between">
              <span class="text-[11px] text-text-muted">
                {article.data.readingTime ? `${article.data.readingTime} 分钟阅读` : '阅读更多'}
              </span>
              <svg class="h-3 w-3 opacity-0 -translate-x-1 text-accent transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
