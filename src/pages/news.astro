---
import Layout from '../layouts/Layout.astro';
import newsData from '../data/news.json';

const generatedAt = new Date(newsData.generatedAt);
const items = newsData.items;
const sources = newsData.sources;

const sourceNames = Array.from(new Set(items.map((item) => item.source))).sort();
const regions = Array.from(new Set(items.map((item) => item.region))).sort();
const allTags = Array.from(new Set(items.flatMap((item) => item.tags))).sort();

function formatDate(value: string) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '未知时间';
  return new Intl.DateTimeFormat('zh-CN', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
}
---

<Layout title="AI资讯 — AI Toolbox" description="聚合全球最新 AI 行业新闻资讯，覆盖模型、产品、创业公司、开源社区和大厂动态。">
  <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <!-- Header -->
    <section class="mb-10 rounded-3xl border border-border bg-gradient-to-br from-surface via-[#1e2240] to-surface p-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <div class="mb-3 inline-flex rounded-full bg-accent/15 px-3 py-1 text-xs text-accent-light">
            🌍 全球 AI 行业动态 · RSS 自动聚合
          </div>
          <h1 class="mb-3 text-3xl font-extrabold sm:text-4xl">AI资讯</h1>
          <p class="max-w-2xl text-text-secondary">
            聚合 TechCrunch、MIT Technology Review、The Decoder、VentureBeat、Google AI Blog、Hugging Face 等公开来源，
            帮你快速跟踪模型、产品、开源、创业公司和大厂动态。
          </p>
        </div>
        <div class="grid grid-cols-3 gap-3 text-center">
          <div class="rounded-xl border border-border bg-bg/40 px-4 py-3">
            <div class="text-2xl font-extrabold text-accent-light">{items.length}</div>
            <div class="text-xs text-text-secondary">资讯条目</div>
          </div>
          <div class="rounded-xl border border-border bg-bg/40 px-4 py-3">
            <div class="text-2xl font-extrabold text-accent-light">{sources.length}</div>
            <div class="text-xs text-text-secondary">信息源</div>
          </div>
          <div class="rounded-xl border border-border bg-bg/40 px-4 py-3">
            <div class="text-2xl font-extrabold text-accent-light">{allTags.length}</div>
            <div class="text-xs text-text-secondary">标签</div>
          </div>
        </div>
      </div>
      <p class="mt-5 text-xs text-text-secondary">
        最近刷新：{generatedAt.toLocaleString('zh-CN')} · 本地刷新命令：<code class="rounded bg-bg/50 px-1.5 py-0.5">npm run fetch:news</code>
      </p>
    </section>

    <!-- Controls -->
    <section class="mb-8 grid gap-4 lg:grid-cols-[1fr_220px_220px]">
      <div class="relative">
        <input
          id="newsSearch"
          type="text"
          placeholder="搜索标题、摘要、来源、标签..."
          class="w-full rounded-xl border border-border bg-surface py-3 pl-12 pr-4 text-sm text-text outline-none transition placeholder:text-text-secondary/60 focus:border-accent"
        />
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-lg">🔍</span>
      </div>
      <select id="sourceFilter" class="rounded-xl border border-border bg-surface px-4 py-3 text-sm text-text outline-none focus:border-accent">
        <option value="all">全部来源</option>
        {sourceNames.map((source) => <option value={source}>{source}</option>)}
      </select>
      <select id="regionFilter" class="rounded-xl border border-border bg-surface px-4 py-3 text-sm text-text outline-none focus:border-accent">
        <option value="all">全部地区</option>
        {regions.map((region) => <option value={region}>{region}</option>)}
      </select>
    </section>

    <!-- Tag chips -->
    <section class="mb-8 flex flex-wrap gap-2" id="tagBar">
      <button data-tag="all" class="tag-chip rounded-full border border-accent bg-accent px-3 py-1.5 text-xs text-white">全部标签</button>
      {allTags.map((tag) => (
        <button data-tag={tag} class="tag-chip rounded-full border border-border bg-surface px-3 py-1.5 text-xs text-text-secondary transition hover:bg-surface-hover hover:text-text">
          #{tag}
        </button>
      ))}
    </section>

    <!-- News grid -->
    <section
      id="newsGrid"
      class="grid gap-4 lg:grid-cols-2"
      data-news={JSON.stringify(items)}
    >
      {items.map((item) => (
        <article class="news-card rounded-2xl border border-border bg-surface p-5 transition hover:-translate-y-0.5 hover:border-accent hover:bg-surface-hover" data-source={item.source} data-region={item.region} data-tags={item.tags.join(',')}>
          <div class="mb-3 flex flex-wrap items-center gap-2 text-xs text-text-secondary">
            <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-accent-light">{item.source}</span>
            <span>{item.region}</span>
            <span>·</span>
            <time datetime={item.publishedAt}>{formatDate(item.publishedAt)}</time>
          </div>
          <h2 class="mb-3 text-lg font-bold leading-snug">
            <a href={item.link} target="_blank" class="transition hover:text-accent-light">
              {item.title}
            </a>
          </h2>
          <p class="mb-4 line-clamp-3 text-sm leading-relaxed text-text-secondary">
            {item.summary || '暂无摘要，请点击标题查看原文。'}
          </p>
          <div class="flex flex-wrap gap-2">
            {item.tags.map((tag) => (
              <span class="rounded-full bg-bg/60 px-2.5 py-0.5 text-xs text-text-secondary">#{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </section>

    <div id="emptyNews" class="hidden py-20 text-center text-text-secondary">
      <div class="mb-4 text-5xl">📰</div>
      <p>没有找到匹配的资讯，试试换个关键词或筛选条件。</p>
    </div>
  </main>
</Layout>

<script>
  const searchInput = document.getElementById('newsSearch') as HTMLInputElement;
  const sourceFilter = document.getElementById('sourceFilter') as HTMLSelectElement;
  const regionFilter = document.getElementById('regionFilter') as HTMLSelectElement;
  const tagBar = document.getElementById('tagBar')!;
  const newsGrid = document.getElementById('newsGrid')!;
  const emptyNews = document.getElementById('emptyNews')!;
  const cards = Array.from(document.querySelectorAll('.news-card')) as HTMLElement[];
  let activeTag = 'all';

  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    const source = sourceFilter.value;
    const region = regionFilter.value;
    let visible = 0;

    cards.forEach((card) => {
      const haystack = card.textContent?.toLowerCase() || '';
      const sourceMatch = source === 'all' || card.dataset.source === source;
      const regionMatch = region === 'all' || card.dataset.region === region;
      const tagMatch = activeTag === 'all' || (card.dataset.tags || '').split(',').includes(activeTag);
      const queryMatch = !q || haystack.includes(q);
      const show = sourceMatch && regionMatch && tagMatch && queryMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible += 1;
    });

    emptyNews.classList.toggle('hidden', visible > 0);
    newsGrid.classList.toggle('hidden', visible === 0);
  }

  searchInput.addEventListener('input', applyFilters);
  sourceFilter.addEventListener('change', applyFilters);
  regionFilter.addEventListener('change', applyFilters);

  tagBar.addEventListener('click', (event) => {
    const button = (event.target as HTMLElement).closest('[data-tag]') as HTMLElement | null;
    if (!button) return;
    activeTag = button.dataset.tag || 'all';
    tagBar.querySelectorAll('[data-tag]').forEach((chip) => {
      chip.classList.toggle('border-accent', chip === button);
      chip.classList.toggle('bg-accent', chip === button);
      chip.classList.toggle('text-white', chip === button);
      chip.classList.toggle('border-border', chip !== button);
      chip.classList.toggle('bg-surface', chip !== button);
      chip.classList.toggle('text-text-secondary', chip !== button);
    });
    applyFilters();
  });
</script>
