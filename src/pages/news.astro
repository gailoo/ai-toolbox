---
import Layout from '../layouts/Layout.astro';
import newsData from '../data/news.json';

interface NewsItem {
  title: string;
  link: string;
  source: string;
  pubDate: string;
  summary?: string;
  region?: string;
  tags?: string[];
}

const raw = newsData as any;
const news: NewsItem[] = (raw?.items || raw || []);
---

<Layout title="AI 资讯 — AI Toolbox">
  <div class="mx-auto max-w-6xl px-5 py-10 sm:py-14">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-text">AI 资讯</h1>
      <p class="mt-2 text-sm text-text-secondary">聚合全球最新 AI 行业动态与前沿资讯</p>
    </div>

    <!-- Search & Filter -->
    <div class="mb-8 flex flex-col sm:flex-row gap-3">
      <div class="group relative flex-1 max-w-md">
        <input
          id="newsSearch"
          type="text"
          placeholder="搜索资讯标题..."
          class="w-full rounded-xl border border-border bg-white/70 py-2.5 pl-9 pr-3 text-sm text-text placeholder:text-text-muted outline-none transition-all focus:border-slate-300 focus:bg-white shadow-sm"
        />
        <svg class="absolute left-3 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-text-muted" viewBox="0 0 16 16" fill="none"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" fill="currentColor"/></svg>
      </div>
      <div id="sourceFilter" class="flex gap-1.5 flex-wrap">
        <button data-source="all" class="filter-btn active text-[12px] px-3 py-1.5 rounded-full border border-slate-300 bg-slate-50/80 text-accent-dim shadow-sm shadow-slate-500/8 font-medium transition-all cursor-pointer">全部来源</button>
        {[...new Set(news.map(n => n.source))].slice(0, 6).map(s => (
          <button data-source={s} class="filter-btn text-[12px] px-3 py-1.5 rounded-full border border-border bg-white/50 text-text-secondary transition-all hover:bg-black/[0.02] cursor-pointer">{s}</button>
        ))}
      </div>
    </div>

    <!-- News grid -->
    <div id="newsGrid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-news={JSON.stringify(news)}>
      {news.slice(0, 30).map((item) => (
        <a
          href={item.link}
          target="_blank"
          rel="noopener noreferrer"
          class="glass-card group block rounded-xl p-5 no-underline"
          data-title={(item.title || '').toLowerCase()}
          data-source={(item.source || '').toLowerCase()}
        >
          <div class="flex items-start justify-between gap-3 mb-2">
            <span class="shrink-0 inline-flex items-center text-[10px] font-medium uppercase tracking-wider px-2 py-0.5 rounded-md bg-slate-50/80 text-text-muted border border-border">
              {item.source}
            </span>
            <time class="shrink-0 text-[10px] text-text-muted tabular-nums">{item.pubDate ? new Date(item.pubDate).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' }) : ''}</time>
          </div>
          <h3 class="text-[14px] font-semibold text-text leading-snug line-clamp-2 group-hover:text-text">{item.title}</h3>
          {(item.summary || item.tags?.length) && (
            <p class="mt-2 text-[12px] text-text-muted line-clamp-2 leading-relaxed">{item.summary || item.tags?.slice(0, 3).join(' · ')}</p>
          )}
          <div class="mt-3 pt-2.5 border-t border-border/50 flex items-center justify-between">
            <span class="text-[11px] text-text-muted">阅读原文</span>
            <svg class="h-3 w-3 opacity-0 -translate-x-1 text-accent transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<script>
  const news = JSON.parse(
    (document.getElementById('newsGrid') as HTMLElement).dataset.news || '[]'
  );
  const grid = document.getElementById('newsGrid')!;
  const searchInput = document.getElementById('newsSearch') as HTMLInputElement;

  function filter() {
    const q = (searchInput.value || '').toLowerCase().trim();
    const cards = grid.querySelectorAll('a');
    cards.forEach(card => {
      const title = (card as HTMLElement).dataset.title || '';
      const match = !q || title.includes(q);
      (card as HTMLElement).style.display = match ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', filter);

  // Source filter buttons
  document.getElementById('sourceFilter')!.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest('[data-source]');
    if (!btn) return;
    document.querySelectorAll('#sourceFilter .filter-btn').forEach(b => {
      const isActive = b === btn;
      if (isActive) {
        b.className = 'filter-btn active text-[12px] px-3 py-1.5 rounded-full border border-slate-300 bg-slate-50/80 text-accent-dim shadow-sm shadow-slate-500/8 font-medium transition-all cursor-pointer';
      } else {
        b.className = 'filter-btn text-[12px] px-3 py-1.5 rounded-full border border-border bg-white/50 text-text-secondary transition-all hover:bg-black/[0.02] cursor-pointer';
      }
    });
    searchInput.value = '';
    filter();
  });
</script>
