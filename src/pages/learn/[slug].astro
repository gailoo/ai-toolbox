---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('learn');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const CATEGORY_INFO: Record<string, { icon: string; label: string }> = {
  foundation: { icon: '🧠', label: '基础概念' },
  prompt: { icon: '✍️', label: 'Prompt' },
  rag: { icon: '📚', label: 'RAG知识库' },
  agent: { icon: '🤖', label: 'Agent' },
  multimodal: { icon: '🖼️', label: '多模态' },
  tools: { icon: '🧰', label: '工具选型' },
  safety: { icon: '🛡️', label: '安全评估' },
};

const levelMap: Record<string, { label: string; color: string }> = {
  beginner: { label: '入门', color: 'bg-green-900/40 text-green-400' },
  intermediate: { label: '进阶', color: 'bg-blue-900/40 text-blue-400' },
  advanced: { label: '高级', color: 'bg-purple-900/40 text-purple-400' },
};

const catInfo = CATEGORY_INFO[article.data.category] || { icon: '📖', label: article.data.category };
const allArticles = await getCollection('learn');
const related = allArticles
  .filter((item) => item.data.category === article.data.category && item.id !== article.id)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 3);
---

<Layout title={`${article.data.title} — AI知识`} description={article.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <nav class="mb-8 flex items-center gap-2 text-sm text-text-secondary">
      <a href="/" class="transition hover:text-text">首页</a>
      <span>/</span>
      <a href="/learn" class="transition hover:text-text">AI知识</a>
      <span>/</span>
      <span class="text-text">{article.data.title}</span>
    </nav>

    <header class="mb-10">
      <div class="mb-4 flex flex-wrap gap-2">
        <span class="rounded-full bg-surface-hover px-3 py-1 text-xs text-text-secondary">
          {catInfo.icon} {catInfo.label}
        </span>
        <span class={`rounded-full px-3 py-1 text-xs ${levelMap[article.data.level].color}`}>
          {levelMap[article.data.level].label}
        </span>
        <span class="rounded-full bg-surface-hover px-3 py-1 text-xs text-text-secondary">
          ⏱ {article.data.readingTime}
        </span>
      </div>
      <h1 class="mb-4 text-3xl font-extrabold leading-tight sm:text-4xl">{article.data.title}</h1>
      <p class="text-lg leading-relaxed text-text-secondary">{article.data.description}</p>
    </header>

    <div class="prose prose-invert max-w-none rounded-2xl border border-border bg-surface p-6 prose-headings:text-text prose-p:text-text-secondary prose-li:text-text-secondary prose-strong:text-text prose-code:text-accent-light">
      <Content />
    </div>

    {article.data.tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {article.data.tags.map((tag: string) => (
          <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs text-text-secondary">#{tag}</span>
        ))}
      </div>
    )}

    {related.length > 0 && (
      <section class="mt-12 border-t border-border pt-8">
        <h2 class="mb-5 text-xl font-bold">继续学习</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {related.map((item) => (
            <a href={`/learn/${item.id}`} class="rounded-xl border border-border bg-surface p-4 transition hover:border-accent hover:bg-surface-hover">
              <div class="mb-2 font-bold">{item.data.title}</div>
              <div class="text-xs text-text-secondary">{item.data.description}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>
