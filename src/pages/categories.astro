---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');

const CATEGORIES = [
  { cat: 'chat', icon: '◆', label: '对话大模型', desc: 'GPT、Claude、Gemini 等大语言模型' },
  { cat: 'ide', icon: '⌘', label: '代码IDE', desc: 'AI 驱动的开发环境与编程助手' },
  { cat: 'ui', icon: '◎', label: 'UI前端', desc: 'AI UI 设计与前端生成工具' },
  { cat: 'agent', icon: '⚡', label: 'Agent编排', desc: '自主执行任务的 AI Agent 框架' },
  { cat: 'media', icon: '◐', label: '图片视频', desc: 'AI 图像生成、视频编辑与多模态创作' },
  { cat: 'search', icon: '⊕', label: '搜索知识', desc: 'AI 搜索引擎与知识管理平台' },
  { cat: 'data', icon: '▣', label: '数据分析', desc: 'AI 数据处理、分析与可视化' },
  { cat: 'audio', icon: '♫', label: '音频音乐', desc: 'AI 音频生成、音乐创作与语音处理' },
];
---

<Layout title="分类浏览 — AI Toolbox">
  <div class="mx-auto max-w-6xl px-5 py-10 sm:py-14">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-text">分类浏览</h1>
      <p class="mt-2 text-sm text-text-secondary">按类别探索全栈 AI 工具生态</p>
    </div>

    <!-- Category Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {CATEGORIES.map((c) => {
        const count = allProducts.filter(p => p.data.category === c.cat).length;
        return (
          <a
            href={`/products?category=${c.cat}`}
            id={c.cat}
            class="glass-card group block rounded-2xl p-6 no-underline"
          >
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-50/80 text-lg border border-border">
                {c.icon}
              </div>
              <div>
                <h2 class="text-[15px] font-semibold text-text group-hover:text-text">{c.label}</h2>
                <span class="text-[11px] tabular-nums text-text-muted">{count} 款工具</span>
              </div>
            </div>
            <p class="text-[12px] text-text-muted leading-relaxed line-clamp-2 mt-1">{c.desc}</p>
            <div class="mt-4 h-px w-0 bg-gradient-to-r from-transparent via-slate-300/30 to-transparent transition-all duration-500 group-hover:w-full"></div>
          </a>
        );
      })}
    </div>

    <!-- All products list below -->
    <div class="mt-14">
      <h2 class="mb-5 text-xs font-semibold uppercase tracking-widest text-text-tertiary">全部工具</h2>
      <div class="grid gap-2 sm:gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {allProducts.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)).map(p => (
          <a href={`/products/${p.id}`} class="glass-card group flex items-center gap-3 rounded-xl p-3.5 no-underline">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-slate-50/60 border border-border text-xs text-text-muted">{CATEGORIES.find(c => c.cat === p.data.category)?.icon || '●'}</div>
            <div class="min-w-0 flex-1">
              <h3 class="text-[13px] font-medium text-text truncate group-hover:text-text">{p.data.name}</h3>
              <p class="text-[11px] text-text-muted truncate">{p.data.vendor}</p>
            </div>
            <svg class="h-3.5 w-3.5 shrink-0 opacity-0 -translate-x-1 text-accent transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
