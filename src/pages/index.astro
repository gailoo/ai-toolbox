---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import FilterTag from '../components/FilterTag.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const sorted = allProducts.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const CATEGORIES = [
  { cat: 'all', icon: '◈', label: '全部' },
  { cat: 'chat', icon: '◆', label: '对话模型' },
  { cat: 'ide', icon: '⌘', label: '代码IDE' },
  { cat: 'ui', icon: '◎', label: 'UI前端' },
  { cat: 'agent', icon: '⚡', label: 'Agent' },
  { cat: 'media', icon: '◐', label: '图片视频' },
  { cat: 'search', icon: '⊕', label: '搜索知识' },
  { cat: 'data', icon: '▣', label: '数据分析' },
  { cat: 'audio', icon: '♫', label: '音频音乐' },
];

const CATEGORY_LABELS: Record<string, string> = {
  chat: '对话大模型',
  ide: '代码IDE',
  ui: 'UI前端',
  agent: 'Agent编排',
  media: '图片视频',
  search: '搜索知识',
  data: '数据分析',
  audio: '音频音乐',
};

const catCounts: Record<string, number> = {};
for (const p of sorted) {
  catCounts[p.data.category] = (catCounts[p.data.category] || 0) + 1;
}
---

<Layout>
  <!-- ═══════════════ Hero Section — Apple-style ═══════════════ -->
  <section class="relative overflow-hidden border-b border-border/40 bg-white">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0 bg-gradient-to-b from-white via-slate-50/[0.4] to-white" />

    <!-- Decorative orbs — Apple neutral -->
    <div class="glow-orb top-[-20%] right-[-10%] h-[500px] w-[500px]" style="background-color: #e8e8ed;" />
    <div class="glow-orb bottom-[-15%] left-[-10%] h-[400px] w-[400px]" style="background-color: #f0f0f4;" />

    <div class="relative mx-auto max-w-6xl px-5 pt-20 pb-16 sm:pt-28 sm:pb-20 text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex justify-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-white/80 backdrop-blur-sm px-4 py-1.5 text-[12px] font-medium text-text-secondary shadow-sm">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-success opacity-60"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-success"></span>
          </span>
          精选全栈开发链路中最具影响力的 AI 工具
        </div>
      </div>

      <!-- Title — Apple-like large typography -->
      <h1 class="text-4xl font-bold tracking-tight sm:text-6xl lg:text-7xl text-text leading-[1.05]">
        发现最好的
        <br />
        <span class="gradient-text">AI 工具</span>
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-xl text-base sm:text-lg text-text-secondary leading-relaxed">
        持续追踪市场上最新 AI 产品，梳理每个工具的核心优势与局限性，助你精准选型。
      </p>

      <!-- Search — Glass style -->
      <div class="mx-auto mt-10 max-w-md">
        <div class="group relative">
          <input
            id="searchInput"
            type="text"
            placeholder="搜索产品名称、厂商或特点..."
            class="w-full rounded-2xl border border-border bg-white/70 py-3.5 pl-11 pr-4 text-sm text-text placeholder:text-text-muted outline-none transition-all duration-200 shadow-sm focus:border-slate-300 focus:bg-white focus:shadow-lg focus:shadow-slate-500/8 backdrop-blur-xl"
          />
          <svg class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-text-muted transition-colors group-focus-within:text-accent" viewBox="0 0 16 16" fill="none"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" fill="currentColor"/></svg>
        </div>
      </div>

      <!-- Stats row — Clean minimal -->
      <div class="mx-auto mt-14 flex max-w-md justify-center items-center gap-8">
        <div class="flex flex-col items-center">
          <div class="text-3xl font-bold tracking-tight gradient-text">{sorted.length}</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wider text-text-muted">收录工具</div>
        </div>
        <div class="w-px h-10 bg-border" />
        <div class="flex flex-col items-center">
          <div class="text-3xl font-bold tracking-tight gradient-text">{CATEGORIES.length - 1}</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wider text-text-muted">分类</div>
        </div>
        <div class="w-px h-10 bg-border" />
        <div class="flex flex-col items-center">
          <div class="text-3xl font-bold tracking-tight gradient-text">2026</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wider text-text-muted">更新</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Filter Bar — Sticky glass ═══ -->
  <section class="sticky top-14 z-40 border-b border-border/40 bg-white/72 backdrop-blur-2xl supports-[backdrop-filter]:bg-white/50">
    <div class="mx-auto max-w-6xl px-5 py-3 overflow-x-auto scrollbar-hide">
      <div class="flex gap-1.5 min-w-max" id="filterBar">
        {CATEGORIES.map((c) => (
          <FilterTag
            icon={c.icon}
            label={c.label}
            cat={c.cat}
            active={c.cat === 'all'}
            count={c.cat === 'all' ? sorted.length : catCounts[c.cat]}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Product Grid ═══ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:py-16">
    <div
      id="productGrid"
      class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 stagger"
      data-products={JSON.stringify(sorted.map(p => ({
        slug: p.id,
        name: p.data.name,
        vendor: p.data.vendor,
        category: p.data.category,
        categoryLabel: CATEGORY_LABELS[p.data.category] || p.data.category,
        pros: p.data.pros,
        cons: p.data.cons,
        pricing: p.data.pricing,
        website: p.data.website,
      })))}
    >
      {sorted.map((p) => (
        <ProductCard
          slug={p.id}
          name={p.data.name}
          vendor={p.data.vendor}
          category={p.data.category}
          categoryLabel={CATEGORY_LABELS[p.data.category] || p.data.category}
          pros={p.data.pros}
          cons={p.data.cons}
          pricing={p.data.pricing}
          website={p.data.website}
        />
      ))}
    </div>

    <!-- Empty state -->
    <div id="emptyState" class="hidden py-24 text-center">
      <div class="mx-auto mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-border bg-white shadow-sm">
        <svg class="h-6 w-6 text-text-muted" viewBox="0 0 16 16" fill="none"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" stroke="currentColor" stroke-width="1.2" opacity="0.35"/></svg>
      </div>
      <p class="text-sm text-text-secondary">没有找到匹配的工具，试试其他关键词</p>
    </div>
  </section>
</Layout>

<script>
  const products = JSON.parse(
    (document.getElementById('productGrid') as HTMLElement).dataset.products || '[]'
  );
  const grid = document.getElementById('productGrid')!;
  const emptyState = document.getElementById('emptyState')!;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const filterBar = document.getElementById('filterBar')!;

  let currentCat = 'all';

  function render(query: string, cat: string) {
    const q = query.toLowerCase().trim();
    const filtered = products.filter(
      (p: any) =>
        (cat === 'all' || p.category === cat) &&
        (!q ||
          p.name.toLowerCase().includes(q) ||
          p.vendor.toLowerCase().includes(q) ||
          p.pros.join(' ').toLowerCase().includes(q) ||
          p.cons.join(' ').toLowerCase().includes(q))
    );

    const cards = grid.querySelectorAll('a');
    cards.forEach((card, i) => {
      const p = products[i];
      const match =
        (cat === 'all' || p.category === cat) &&
        (!q ||
          p.name.toLowerCase().includes(q) ||
          p.vendor.toLowerCase().includes(q) ||
          p.pros.join(' ').toLowerCase().includes(q) ||
          p.cons.join(' ').toLowerCase().includes(q));
      (card as HTMLElement).style.display = match ? '' : 'none';
    });

    const visibleCount = Array.from(cards).filter(
      (c) => (c as HTMLElement).style.display !== 'none'
    ).length;
    emptyState.classList.toggle('hidden', visibleCount > 0);
    grid.classList.toggle('hidden', visibleCount === 0);
  }

  searchInput.addEventListener('input', () => render(searchInput.value, currentCat));

  filterBar.addEventListener('click', (e) => {
    const tag = (e.target as HTMLElement).closest('[data-cat]');
    if (!tag) return;
    currentCat = (tag as HTMLElement).dataset.cat!;
    filterBar.querySelectorAll('[data-cat]').forEach((t) => {
      const isActive = t === tag;
      t.classList.toggle('border-slate-300', isActive);
      t.classList.toggle('bg-slate-50/80', isActive);
      t.classList.toggle('text-accent-dim', isActive);
      t.classList.toggle('shadow-sm', isActive);
      t.classList.toggle('shadow-slate-500/8', isActive);
      t.classList.toggle('border-border', !isActive);
      t.classList.toggle('bg-white/50', !isActive);
      t.classList.toggle('text-text-secondary', !isActive);
    });
    render(searchInput.value, currentCat);
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
