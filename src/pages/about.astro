---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 — AI Toolbox">
  <div class="mx-auto max-w-3xl px-5 py-10 sm:py-14">
    <!-- Header -->
    <div class="mb-10 text-center">
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-text">关于</h1>
      <p class="mt-2 text-sm text-text-secondary">关于 AI Toolbox 的理念与愿景</p>
    </div>

    <!-- Mission Card -->
    <div class="glass-card rounded-2xl p-6 sm:p-8 mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-text-tertiary mb-4">使命</h2>
      <p class="text-[15px] leading-relaxed text-text-secondary">
        AI Toolbox 致力于为开发者和产品经理提供一份清晰、客观、持续更新的 AI 工具导航。
        在 AI 产品爆炸式增长的今天，我们帮你快速了解每款工具的核心优势与局限，
        做出更明智的技术选型决策。
      </p>
    </div>

    <!-- Features -->
    <div class="glass-card rounded-2xl p-6 sm:p-8 mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-text-tertiary mb-4">特点</h2>
      <ul class="space-y-3">
        {[
          { icon: '◈', title: '精选收录', desc: '只收录市场上真正有影响力的 AI 产品' },
          { icon: '⚡', title: '多维评估', desc: '每个工具都标注核心优势与局限性' },
          { icon: '◎', title: '分类清晰', desc: '按全栈开发链路分类，快速定位所需工具' },
          { icon: '◆', title: '持续更新', desc: '定期追踪市场动态，保持内容时效性' },
        ].map(item => (
          <li class="flex items-start gap-3">
            <span class="shrink-0 mt-0.5 text-sm text-accent">{item.icon}</span>
            <div>
              <span class="text-[13px] font-medium text-text">{item.title}</span>
              <p class="text-[12px] text-text-muted mt-0.5">{item.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Tech Stack -->
    <div class="glass-card rounded-2xl p-6 sm:p-8 mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-text-tertiary mb-4">技术栈</h2>
      <div class="flex flex-wrap gap-2 justify-center">
        {['Astro', 'MDX', 'Tailwind CSS v4', 'TypeScript', 'Static Site'].map(tag => (
          <span class="text-[11px] px-2.5 py-1 rounded-lg border border-border bg-slate-50/60 text-text-secondary">{tag}</span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="glass-card rounded-2xl p-6 sm:p-8 text-center">
      <img src="/avatar.jpg" alt="AI Toolbox" class="w-14 h-14 rounded-full mx-auto mb-4 object-cover ring-1 ring-border" />
      <p class="text-[13px] text-text-secondary mb-4">AI Toolbox · Built with care</p>
      <a
        href="https://github.com/gailoo/ai-toolbox"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-xl bg-gradient-to-r from-slate-700 to-slate-800 text-white px-5 py-2.5 text-[13px] font-medium transition-all hover:from-slate-800 hover:to-slate-900 hover:shadow-lg hover:shadow-slate-500/20"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.53 1.03 1.53 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.516-4.477-10-10-10z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</Layout>
