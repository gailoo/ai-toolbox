---
interface Props {
  slug: string;
  name: string;
  vendor: string;
  category: string;
  categoryLabel: string;
  pros: string[];
  cons: string[];
  pricing: string;
  website: string;
}

const { slug, name, vendor, categoryLabel, pros, cons, pricing, website } = Astro.props;

const PRICING_MAP: Record<string, { label: string; color: string }> = {
  free: { label: '免费', color: 'text-emerald-600' },
  freemium: { label: '免费增值', color: 'text-sky-600' },
  paid: { label: '付费', color: 'text-text' },
  enterprise: { label: '企业', color: 'text-text' },
};

const priceInfo = PRICING_MAP[pricing] || { label: pricing, color: 'text-text-secondary' };
---

<a href={`/products/${slug}`} class="glass-card glass-shine group block rounded-2xl p-5 no-underline">
  <!-- Top accent line — appears on hover -->
  <div class="h-px w-0 bg-gradient-to-r from-transparent via-slate-400/40 to-transparent transition-all duration-500 group-hover:w-full mb-4" />

  <!-- Header -->
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <h3 class="text-[15px] font-semibold text-text truncate group-hover:text-text">{name}</h3>
      <p class="mt-0.5 text-[12px] text-text-muted truncate">{vendor}</p>
    </div>
    <!-- Pricing tag -->
    <span class={`shrink-0 inline-flex items-center rounded-lg px-2 py-0.5 text-[10px] font-medium border border-border bg-white/50 ${priceInfo.color}`}>
      {priceInfo.label}
    </span>
  </div>

  <!-- Category badge -->
  <div class="mt-3">
    <span class="inline-block text-[11px] font-medium text-text-tertiary bg-slate-50/80 px-2 py-0.5 rounded-md">
      {categoryLabel}
    </span>
  </div>

  <!-- Pros — compact list -->
  {pros.length > 0 && (
    <ul class="mt-3 space-y-1">
      {pros.slice(0, 2).map((pro) => (
        <li class="flex items-start gap-2 text-[12px] text-text-secondary">
          <svg class="mt-0.5 h-3 w-3 shrink-0 text-emerald-500" viewBox="0 0 12 12" fill="none"><path d="M10 3L4.5 8.5L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="line-clamp-1">{pro}</span>
        </li>
      ))}
    </ul>
  )}

  <!-- Footer: view link -->
  <div class="mt-4 pt-3 border-t border-border/60 flex items-center justify-between">
    <span class="text-[11px] text-text-muted">查看详情</span>
    <svg class="h-3.5 w-3.5 -translate-x-1 opacity-0 text-accent transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</a>
