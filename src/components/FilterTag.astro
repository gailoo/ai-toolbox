---
interface Props {
  icon: string;
  label: string;
  cat: string;
  active?: boolean;
  count?: number;
}

const { icon, label, cat, active = false, count } = Astro.props;
---

<button
  data-cat={cat}
  class:list={[
    'filter-tag cursor-pointer whitespace-nowrap rounded-full border px-4 py-2 text-sm transition-all',
    active
      ? 'border-accent bg-accent text-white'
      : 'border-border bg-surface text-text-secondary hover:bg-surface-hover hover:text-text',
  ]}
>
  {icon} {label}
  {count != null && <span class="ml-1 opacity-70">({count})</span>}
</button>
