---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AI Toolbox — AI 产品导航',
  description = '精选全栈开发链路中最具影响力的 AI 产品，每个工具都标注优势与局限。',
} = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased bg-bg text-text">

    <!-- ═══ Navbar — Glass style ═══ -->
    <nav class="sticky top-0 z-50 border-b border-border/60 bg-white/72 backdrop-blur-2xl supports-[backdrop-filter]:bg-white/60">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-5 h-14">
        <!-- Logo — Avatar -->
        <a href="/" class="group flex items-center gap-2.5">
          <img
            src="/avatar.jpg"
            alt="AI Toolbox"
            class="avatar-logo"
          />
          <span class="text-sm font-semibold tracking-tight text-text">
            AI Toolbox<span class="gradient-text ml-0.5">.</span>
          </span>
        </a>

        <!-- Nav links — Chinese labels restored -->
        <div class="hidden md:flex items-center gap-0.5">
          <a href="/" class="hover-underline px-3 py-1.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-text rounded-lg hover:bg-black/[0.03]">首页</a>
          <a href="/categories" class="hover-underline px-3 py-1.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-text rounded-lg hover:bg-black/[0.03]">分类</a>
          <a href="/news" class="hover-underline px-3 py-1.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-text rounded-lg hover:bg-black/[0.03]">AI资讯</a>
          <a href="/learn" class="hover-underline px-3 py-1.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-text rounded-lg hover:bg-black/[0.03]">AI知识</a>
          <a href="/about" class="hover-underline px-3 py-1.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-text rounded-lg hover:bg-black/[0.03]">关于</a>
        </div>

        <!-- Right: GitHub link -->
        <a
          href="https://github.com/gailoo/ai-toolbox"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-xl bg-black/[0.04] border border-border px-3.5 py-1.5 text-[12px] font-medium text-text-secondary transition-all hover:bg-black/[0.06] hover:border-border-hover hover:text-text"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.53 1.03 1.53 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.516-4.477-10-10-10z"/></svg>
          GitHub
        </a>
      </div>
    </nav>

    <slot />

    <!-- ═══ Footer ═══ -->
    <footer class="border-t border-border/60 mt-auto bg-white/40 backdrop-blur-sm">
      <div class="mx-auto max-w-6xl px-5 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2.5 text-xs text-text-muted">
            <span>© 2026</span>
            <span class="text-border-hover">·</span>
            <span class="font-medium text-text-secondary">AI Toolbox</span>
            <span class="text-border-hover">· Built with Astro & Tailwind CSS</span>
          </div>
          <div class="flex items-center gap-4 text-xs text-text-muted">
            <a href="https://github.com/gailoo/ai-toolbox" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-text-secondary">Source</a>
            <span class="text-border-hover">·</span>
            <a href="/about" class="transition-colors hover:text-text-secondary">About</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
